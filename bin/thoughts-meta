#!/usr/bin/env bash
# thoughts-meta — Gather metadata for the thoughts_writer agent.
# Permissively collects date and git info; missing values become "unknown".
set -euo pipefail

iso_date=$(date -u "+%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "unknown")
file_date=$(date "+%Y-%m-%d" 2>/dev/null || echo "unknown")
file_time=$(date "+%H-%M-%S" 2>/dev/null || echo "unknown")

git_commit=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
git_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
repo_name=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || echo "unknown")

cat <<EOF
iso_date: ${iso_date}
file_date: ${file_date}
file_time: ${file_time}
git_commit: ${git_commit}
git_branch: ${git_branch}
repository: ${repo_name}
EOF
